# Groq API — used for generation, reranking, citation verification, and confidence scoring
GROQ_API_KEY=your_groq_api_key_here

# Google API — currently unused by the active embedder (local sentence-transformers is used instead),
# kept for compatibility with the commented-out Gemini embedding code paths in embedder.py/chunker.py
GOOGLE_API_KEY=your_google_api_key_here

# Tavily API — used for the "Learn More on Web" search fallback feature
TAVILY_API_KEY=your_tavily_api_key_here